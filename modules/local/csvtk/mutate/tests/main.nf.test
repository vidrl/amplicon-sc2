nextflow_process {

    name "Test Process CSVTK_MUTATE"
    script "../main.nf"
    process "CSVTK_MUTATE"
    config "./nextflow.config"

    tag "modules"
    tag "modules_"
    tag "csvtk"
    tag "csvtk/mutate"
    
    test("mutate - tsv") {

        when {
            params {
                csvtk_args = "--fields 1 --name 'newCol' --pattern '(\\d+).*'"
            }
            process {
                """
                input[0] = [
                    [ id:'test' ],
                    [
                        file("https://github.com/nf-core/test-datasets/raw/bacass/bacass_hybrid.csv", checkIfExists: true),
                    ]
                ]
                input[1] = "tsv"
                input[2] = "tsv"
                input[3] = "mutate"
                """
            }
        }

        then {
            assert path(process.out.csv[0][1]).md5 == "9db267773e69cf5ba949963cf1d2eb38"
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }

    test("mutate2") {

        when {
            params {
                csvtk_args = "--name 'newCol' --expression '\$1 + \$6'"
            }
            process {
                """
                input[0] = [
                    [ id:'test' ],
                    [
                        file("https://github.com/nf-core/test-datasets/raw/bacass/bacass_hybrid.csv", checkIfExists: true),
                    ]
                ]
                input[1] = "tsv"
                input[2] = "tsv"
                input[3] = "mutate2"
                """
            }
        }

        then {
            assert path(process.out.csv[0][1]).md5 == "64745b164921f3002b1cfa782146eb52"
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }

    test("mutate3") {
        when {
            params {
                csvtk_args = "--name 'newCol' --expression '\$1 ?? \$6'"
            }
            process {
                """
                input[0] = [
                    [ id:'test' ],
                    [
                        file("https://github.com/nf-core/test-datasets/raw/bacass/bacass_hybrid.csv", checkIfExists: true),
                    ]
                ]
                input[1] = "tsv"
                input[2] = "tsv"
                input[3] = "mutate3"
                """
            }
        }

        then {
            assert path(process.out.csv[0][1]).md5 == "370505b81d53904b3dcd4487889731ae"
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }
}
